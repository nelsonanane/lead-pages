---
interface Props {
  title: string;
  headline: string;
  subtitle: string;
  pdfUrl: string;
  valueProps: string[];
  ctaText: string;
  previewDescription: string;
  pages: number;
  type: string;
  slug: string;
}

const { title, headline, subtitle, pdfUrl, valueProps, ctaText, previewDescription, pages, type, slug } = Astro.props;

const typeLabels: Record<string, string> = {
  'guide': 'Guide',
  'cheatsheet': 'Cheatsheet',
  'checklist': 'Checklist',
  'quick-reference': 'Quick Reference',
  'how-to-guide': 'How-To Guide',
};
const typeLabel = typeLabels[type] || 'Guide';
const badge = `Free ${pages}-Page ${typeLabel}`;
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={subtitle} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Kode+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:           #0E0E12;
      --bg-card:      #141418;
      --bg-hero:      #111108;
      --ink:          #F0EDE0;
      --accent:       #F0C030;
      --accent-dark:  #C49B20;
      --accent-dim:   rgba(240, 192, 48, 0.08);
      --rule:         rgba(240, 192, 48, 0.12);
      --muted:        rgba(240, 237, 224, 0.42);
      --font:         'Kode Mono', 'Courier New', monospace;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--ink);
      font-family: var(--font);
    }

    /* Subtle scanline texture */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background-image: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0,0,0,0.03) 2px,
        rgba(0,0,0,0.03) 4px
      );
      pointer-events: none;
      z-index: 9999;
    }

    .wrap { max-width: 760px; margin: 0 auto; padding: 0 32px; }

    /* ── Nav ───────────────────────────────────────── */
    nav {
      border-bottom: 1px solid var(--rule);
      padding: 18px 0;
    }
    nav .wrap {
      max-width: 1100px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .nav-brand {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      text-decoration: none;
    }
    .nav-link {
      font-size: 0.68rem;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-link:hover { color: var(--accent); }

    /* ── Hero ──────────────────────────────────────── */
    .hero {
      background: var(--bg-hero);
      border-bottom: 1px solid var(--rule);
      padding: 72px 0 60px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    /* gold gradient glow behind hero content */
    .hero::before {
      content: '';
      position: absolute;
      top: 0; left: 50%;
      transform: translateX(-50%);
      width: 600px;
      height: 200px;
      background: radial-gradient(ellipse at top, rgba(240,192,48,0.08) 0%, transparent 70%);
      pointer-events: none;
    }

    .badge {
      display: inline-block;
      font-size: 0.6rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      border: 1px solid rgba(240,192,48,0.35);
      padding: 6px 18px;
      margin-bottom: 32px;
      position: relative;
    }

    .hero h1 {
      font-size: clamp(1.9rem, 5vw, 3rem);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.01em;
      margin-bottom: 18px;
      max-width: 620px;
      margin-left: auto;
      margin-right: auto;
      text-shadow: 2px 3px 0px rgba(0,0,0,0.6);
    }

    .hero-sub {
      font-size: 0.85rem;
      color: var(--muted);
      line-height: 1.8;
      max-width: 460px;
      margin: 0 auto 40px;
    }

    /* ── Value props ───────────────────────────────── */
    .props-list { text-align: left; max-width: 380px; margin: 0 auto; }
    .prop-item {
      display: flex;
      gap: 14px;
      align-items: flex-start;
      padding: 10px 0;
      border-top: 1px solid var(--rule);
      font-size: 0.78rem;
      color: var(--ink);
      line-height: 1.6;
    }
    .prop-item::before {
      content: '›';
      color: var(--accent);
      font-weight: 700;
      flex-shrink: 0;
      font-size: 1rem;
      line-height: 1.4;
    }

    /* ── Form card ─────────────────────────────────── */
    .form-wrap { padding: 0 32px 72px; }
    .form-card {
      background: var(--bg-card);
      border: 1px solid var(--rule);
      padding: 48px;
      max-width: 500px;
      margin: -36px auto 0;
      position: relative;
      box-shadow: 0 0 40px rgba(240,192,48,0.04);
    }

    .form-heading {
      font-size: 1.3rem;
      font-weight: 700;
      text-align: center;
      margin-bottom: 6px;
      color: var(--ink);
    }
    .form-sub {
      font-size: 0.72rem;
      color: var(--muted);
      text-align: center;
      margin-bottom: 28px;
      line-height: 1.7;
    }

    .field { margin-bottom: 16px; }
    .field label {
      display: block;
      font-size: 0.62rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 6px;
    }
    .field input {
      width: 100%;
      padding: 12px 16px;
      border: 1px solid rgba(240,192,48,0.2);
      background: var(--bg);
      font-family: var(--font);
      font-size: 0.85rem;
      color: var(--ink);
      outline: none;
      transition: border-color 0.2s;
    }
    .field input:focus { border-color: var(--accent); }
    .field input::placeholder { color: rgba(240,237,224,0.18); }

    .submit-btn {
      width: 100%;
      background: var(--accent);
      color: #0E0E12;
      font-family: var(--font);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 15px;
      border: none;
      cursor: pointer;
      transition: background 0.2s, box-shadow 0.2s;
      margin-top: 4px;
    }
    .submit-btn:hover {
      background: var(--accent-dark);
      box-shadow: 0 0 20px rgba(240,192,48,0.2);
    }

    .no-spam {
      font-size: 0.6rem;
      color: rgba(240,237,224,0.2);
      text-align: center;
      margin-top: 10px;
    }

    /* ── Success state ─────────────────────────────── */
    .success-wrap { text-align: center; padding: 16px 0; }
    .check-icon {
      width: 52px;
      height: 52px;
      background: var(--accent-dim);
      border: 1px solid rgba(240,192,48,0.3);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px;
    }
    .success-heading { font-size: 1.3rem; font-weight: 700; margin-bottom: 6px; }
    .success-sub {
      font-size: 0.75rem;
      color: var(--muted);
      margin-bottom: 24px;
    }
    .download-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--accent);
      color: #0E0E12;
      font-family: var(--font);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 14px 28px;
      text-decoration: none;
      transition: background 0.2s, box-shadow 0.2s;
    }
    .download-btn:hover {
      background: var(--accent-dark);
      box-shadow: 0 0 20px rgba(240,192,48,0.2);
    }

    /* ── Prose ─────────────────────────────────────── */
    .body-content {
      padding: 64px 0;
      border-top: 1px solid var(--rule);
    }
    .prose-body { font-size: 0.85rem; line-height: 1.85; color: var(--muted); }
    .prose-body h2 { font-size: 1.2rem; font-weight: 700; color: var(--ink); margin: 36px 0 12px; }
    .prose-body h3 { font-size: 1rem; font-weight: 700; color: var(--ink); margin: 24px 0 8px; }
    .prose-body p { margin-bottom: 16px; }
    .prose-body strong { color: var(--accent); font-weight: 700; }
    .prose-body a { color: var(--accent); text-decoration: none; }
    .prose-body a:hover { text-decoration: underline; }
    .prose-body ul { padding-left: 20px; margin-bottom: 16px; }
    .prose-body li { margin-bottom: 6px; }

    /* ── Footer ────────────────────────────────────── */
    footer {
      border-top: 1px solid var(--rule);
      padding: 24px 0;
      text-align: center;
    }
    footer span {
      font-size: 0.6rem;
      color: rgba(240,237,224,0.18);
    }

    .hidden { display: none !important; }

    @media (max-width: 600px) {
      .wrap, .form-wrap { padding: 0 20px; }
      .form-card { padding: 32px 24px; }
      .hero { padding: 52px 0 44px; }
    }
  </style>
</head>
<body>

  <!-- Nav -->
  <nav>
    <div class="wrap" style="max-width: 1100px;">
      <a href="/" class="nav-brand">@thenelsonkwesi</a>
      <a href="https://nelsonkwesi.xyz" class="nav-link">More resources &rarr;</a>
    </div>
  </nav>

  <!-- Hero -->
  <div class="hero">
    <div class="wrap">
      <span class="badge">{badge}</span>
      <h1>{headline}</h1>
      <p class="hero-sub">{subtitle}</p>
      <div class="props-list">
        {valueProps.map((prop) => (
          <div class="prop-item">{prop}</div>
        ))}
      </div>
    </div>
  </div>

  <!-- Form Card -->
  <div class="form-wrap">
    <div class="form-card">
      <div id="form-section">
        <h2 class="form-heading">Get Instant Access</h2>
        <p class="form-sub">{previewDescription}</p>
        <form id="lead-form">
          <div class="field">
            <label for="name">First Name</label>
            <input type="text" id="name" name="name" required placeholder="Your first name" />
          </div>
          <div class="field">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required placeholder="you@example.com" />
          </div>
          <button type="submit" class="submit-btn">{ctaText}</button>
          <p class="no-spam">No spam. Unsubscribe anytime.</p>
        </form>
      </div>

      <!-- Success state -->
      <div id="resource-reveal" class="hidden success-wrap">
        <div class="check-icon">
          <svg width="22" height="22" fill="none" stroke="#F0C030" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h3 class="success-heading">Here's your {typeLabel.toLowerCase()}!</h3>
        <p class="success-sub">Click below to view or download.</p>
        <a href={pdfUrl} target="_blank" rel="noopener noreferrer" class="download-btn">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          View &amp; Download {typeLabel}
        </a>
      </div>
    </div>
  </div>

  <!-- Body content -->
  <div class="body-content">
    <div class="wrap prose-body">
      <slot />
    </div>
  </div>

  <!-- Footer -->
  <footer>
    <span>&copy; {new Date().getFullYear()} @thenelsonkwesi</span>
  </footer>

  <script define:vars={{ slug }}>
    const form = document.getElementById('lead-form');
    const reveal = document.getElementById('resource-reveal');
    const formSection = document.getElementById('form-section');

    async function captureLead(name, email) {
      const res = await fetch('/api/capture-lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, resource: slug }),
      });
      if (!res.ok) throw new Error('Failed');
    }

    function showResource() {
      formSection.classList.add('hidden');
      reveal.classList.remove('hidden');
    }

    const params = new URLSearchParams(window.location.search);
    const mcName = params.get('name') || params.get('first_name') || '';
    const mcEmail = params.get('email') || '';

    if (mcName && mcEmail) {
      captureLead(mcName, mcEmail).catch(() => {});
      showResource();
    } else if (mcEmail) {
      document.getElementById('email').value = mcEmail;
    } else if (mcName) {
      document.getElementById('name').value = mcName;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]');
      const originalText = btn.textContent;
      btn.textContent = 'Sending...';
      btn.disabled = true;

      const name = form.querySelector('#name').value.trim();
      const email = form.querySelector('#email').value.trim();

      try {
        await captureLead(name, email);
        showResource();
      } catch (err) {
        btn.textContent = originalText;
        btn.disabled = false;
        showResource();
      }
    });
  </script>
</body>
</html>
