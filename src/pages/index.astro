---
import { getCollection } from 'astro:content';

const allResources = await getCollection('resources');
const resources = allResources.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Free Resources — @thenelsonkwesi</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Courier+Prime:wght@400;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --ink:    #1A1035;
      --bg:     #FAFAF8;
      --accent: #15803D;
      --rule:   rgba(26, 16, 53, 0.09);
      --muted:  rgba(26, 16, 53, 0.38);
      --serif:  'Playfair Display', Georgia, serif;
      --mono:   'Courier Prime', 'Courier New', monospace;
    }
    html { scroll-behavior: smooth; }
    body { background: var(--bg); color: var(--ink); font-family: var(--serif); }

    nav {
      border-bottom: 1px solid var(--rule);
      padding: 18px 0;
    }
    nav .wrap {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .nav-brand {
      font-family: var(--mono);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ink);
      text-decoration: none;
    }
    .nav-link {
      font-family: var(--mono);
      font-size: 0.68rem;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-link:hover { color: var(--ink); }

    .wrap { max-width: 1100px; margin: 0 auto; padding: 0 52px; }

    .page-header {
      padding: 64px 0 48px;
      border-bottom: 1px solid var(--rule);
    }
    .eyebrow {
      font-family: var(--mono);
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 20px;
    }
    .eyebrow::before {
      content: '';
      display: block;
      width: 20px;
      height: 1px;
      background: var(--accent);
      flex-shrink: 0;
    }
    .page-header h1 {
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 900;
      line-height: 1.05;
      letter-spacing: -0.025em;
      margin-bottom: 10px;
    }
    .page-header p {
      font-family: var(--mono);
      font-size: 0.82rem;
      color: var(--muted);
      line-height: 1.7;
    }

    .resources-list { padding: 48px 0 80px; }
    .empty {
      font-family: var(--mono);
      font-size: 0.8rem;
      color: var(--muted);
      padding: 48px 0;
    }

    .resource-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 24px;
      padding: 28px 0;
      border-top: 1px solid var(--rule);
      text-decoration: none;
      color: inherit;
      transition: background 0.15s;
    }
    .resource-item:last-child { border-bottom: 1px solid var(--rule); }
    .resource-item:hover .resource-title { color: var(--accent); }
    .resource-item:hover .resource-arrow { color: var(--accent); transform: translateX(4px); }

    .resource-title {
      font-size: 1.05rem;
      font-weight: 700;
      margin-bottom: 6px;
      transition: color 0.2s;
    }
    .resource-desc {
      font-family: var(--mono);
      font-size: 0.75rem;
      color: var(--muted);
      line-height: 1.6;
      max-width: 560px;
    }
    .resource-meta {
      font-family: var(--mono);
      font-size: 0.68rem;
      color: var(--accent);
      white-space: nowrap;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .resource-arrow {
      display: inline-block;
      transition: transform 0.2s, color 0.2s;
    }

    footer {
      border-top: 1px solid var(--rule);
      padding: 24px 0;
    }
    footer .wrap {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .footer-copy {
      font-family: var(--mono);
      font-size: 0.62rem;
      color: rgba(26,16,53,0.22);
    }
    .footer-cta {
      font-family: var(--mono);
      font-size: 0.68rem;
      color: var(--accent);
      text-decoration: none;
      font-weight: 700;
      transition: opacity 0.2s;
    }
    .footer-cta:hover { opacity: 0.7; }

    @media (max-width: 680px) {
      .wrap { padding: 0 24px; }
      .resource-item { flex-direction: column; align-items: flex-start; gap: 12px; }
    }
  </style>
</head>
<body>

  <nav>
    <div class="wrap">
      <a href="/" class="nav-brand">@thenelsonkwesi</a>
      <a href="/ai-audit" class="nav-link">Book an AI Audit &rarr;</a>
    </div>
  </nav>

  <div class="page-header">
    <div class="wrap">
      <p class="eyebrow">Free Resources</p>
      <h1>Guides, cheatsheets,<br/>and checklists.</h1>
      <p>Practical tools to help you automate your business — no tech skills needed.</p>
    </div>
  </div>

  <div class="resources-list">
    <div class="wrap">
      {resources.length === 0 ? (
        <p class="empty">No resources yet. Check back soon.</p>
      ) : (
        resources.map((r) => (
          <a href={`/${r.id.replace(/\.md$/, '')}`} class="resource-item">
            <div>
              <h2 class="resource-title">{r.data.title}</h2>
              <p class="resource-desc">{r.data.previewDescription}</p>
            </div>
            <span class="resource-meta">
              {r.data.pages}-page {r.data.type}
              <span class="resource-arrow">&rarr;</span>
            </span>
          </a>
        ))
      )}
    </div>
  </div>

  <footer>
    <div class="wrap">
      <span class="footer-copy">&copy; {new Date().getFullYear()} @thenelsonkwesi</span>
      <a href="/ai-audit" class="footer-cta">Book an AI Audit &rarr;</a>
    </div>
  </footer>

</body>
</html>
