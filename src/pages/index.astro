---
import { getCollection } from 'astro:content';

const allResources = await getCollection('resources');
const resources = allResources.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Free Resources — @thenelsonkwesi</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Kode+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:      #0E0E12;
      --bg-hero: #111108;
      --ink:     #F0EDE0;
      --accent:  #F0C030;
      --rule:    rgba(240, 192, 48, 0.12);
      --muted:   rgba(240, 237, 224, 0.42);
      --font:    'Kode Mono', 'Courier New', monospace;
    }
    html { scroll-behavior: smooth; }
    body { background: var(--bg); color: var(--ink); font-family: var(--font); }

    .wrap { max-width: 1100px; margin: 0 auto; padding: 0 52px; }

    /* ── Nav ── */
    nav {
      border-bottom: 1px solid var(--rule);
      padding: 18px 0;
    }
    nav .wrap {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .nav-brand {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      text-decoration: none;
    }
    .nav-link {
      font-size: 0.68rem;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-link:hover { color: var(--accent); }

    /* ── Header ── */
    .page-header {
      padding: 72px 0 52px;
      border-bottom: 1px solid var(--rule);
      position: relative;
      overflow: hidden;
    }
    .page-header::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 400px;
      height: 300px;
      background: radial-gradient(ellipse at top left, rgba(240,192,48,0.06) 0%, transparent 70%);
      pointer-events: none;
    }
    .eyebrow {
      font-size: 0.58rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 20px;
    }
    .eyebrow::before {
      content: '';
      display: block;
      width: 20px;
      height: 1px;
      background: var(--accent);
      flex-shrink: 0;
    }
    .page-header h1 {
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight: 700;
      line-height: 1.1;
      margin-bottom: 12px;
      text-shadow: 2px 3px 0px rgba(0,0,0,0.5);
    }
    .page-header p {
      font-size: 0.8rem;
      color: var(--muted);
      line-height: 1.75;
    }

    /* ── List ── */
    .resources-list { padding: 48px 0 100px; }
    .empty {
      font-size: 0.8rem;
      color: var(--muted);
      padding: 48px 0;
    }

    .resource-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 24px;
      padding: 28px 0;
      border-top: 1px solid var(--rule);
      text-decoration: none;
      color: inherit;
      transition: background 0.15s;
    }
    .resource-item:last-child { border-bottom: 1px solid var(--rule); }
    .resource-item:hover .resource-title { color: var(--accent); }
    .resource-item:hover .resource-arrow { color: var(--accent); transform: translateX(4px); }

    .resource-title {
      font-size: 1rem;
      font-weight: 700;
      margin-bottom: 6px;
      transition: color 0.2s;
    }
    .resource-desc {
      font-size: 0.73rem;
      color: var(--muted);
      line-height: 1.65;
      max-width: 560px;
    }
    .resource-meta {
      font-size: 0.66rem;
      color: var(--accent);
      white-space: nowrap;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .resource-arrow {
      display: inline-block;
      transition: transform 0.2s, color 0.2s;
    }

    /* ── Footer ── */
    footer {
      border-top: 1px solid var(--rule);
      padding: 24px 0;
    }
    footer .wrap {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .footer-copy {
      font-size: 0.6rem;
      color: rgba(240,237,224,0.18);
    }
    .footer-cta {
      font-size: 0.66rem;
      color: var(--accent);
      text-decoration: none;
      font-weight: 700;
      transition: opacity 0.2s;
    }
    .footer-cta:hover { opacity: 0.7; }

    @media (max-width: 680px) {
      .wrap { padding: 0 24px; }
      .resource-item { flex-direction: column; align-items: flex-start; gap: 12px; }
    }
  </style>
</head>
<body>

  <nav>
    <div class="wrap">
      <a href="/" class="nav-brand">@thenelsonkwesi</a>
      <a href="/ai-audit" class="nav-link">Book an AI Audit &rarr;</a>
    </div>
  </nav>

  <div class="page-header">
    <div class="wrap">
      <p class="eyebrow">Free Resources</p>
      <h1>Guides, cheatsheets,<br/>and checklists.</h1>
      <p>Practical tools to help you use AI to build income and save time — no fluff.</p>
    </div>
  </div>

  <div class="resources-list">
    <div class="wrap">
      {resources.length === 0 ? (
        <p class="empty">No resources yet. Check back soon.</p>
      ) : (
        resources.map((r) => (
          <a href={`/${r.id.replace(/\.md$/, '')}`} class="resource-item">
            <div>
              <h2 class="resource-title">{r.data.title}</h2>
              <p class="resource-desc">{r.data.previewDescription}</p>
            </div>
            <span class="resource-meta">
              {r.data.pages}p {r.data.type}
              <span class="resource-arrow">&rarr;</span>
            </span>
          </a>
        ))
      )}
    </div>
  </div>

  <footer>
    <div class="wrap">
      <span class="footer-copy">&copy; {new Date().getFullYear()} @thenelsonkwesi</span>
      <a href="/ai-audit" class="footer-cta">Book an AI Audit &rarr;</a>
    </div>
  </footer>

</body>
</html>
