---
const title = "Book an AI Audit — @thenelsonkwesi";
const headline = "Your Business. Automated. In One Session.";
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="A 30-minute AI Audit that maps your workflow, builds a live automation, and delivers a one-page report showing exactly what it saves you. $500 flat." />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'Inter', sans-serif; background: #fff; color: #1a1035; }
    .accent { color: #7c3aed; }
    .bg-accent { background: #7c3aed; }
    .bg-accent-light { background: #f0eaff; }
    .border-accent { border-color: #7c3aed; }
  </style>
</head>
<body class="antialiased">

  <!-- Nav -->
  <nav style="border-bottom: 1px solid #f3f4f6; padding: 16px 24px;">
    <div style="max-width: 800px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center;">
      <span style="font-weight: 800; font-size: 1rem;">@thenelsonkwesi</span>
      <a href="https://lead-pages-2.vercel.app" style="font-size: 0.875rem; color: #6b7280;">Free Resources →</a>
    </div>
  </nav>

  <!-- Hero -->
  <section style="background: linear-gradient(to bottom, #f0eaff, #fff); padding: 64px 24px 48px;">
    <div style="max-width: 720px; margin: 0 auto; text-align: center;">
      <span style="display: inline-block; background: #ede9fe; color: #7c3aed; font-size: 0.8rem; font-weight: 700; padding: 6px 14px; border-radius: 999px; margin-bottom: 20px; letter-spacing: 0.05em; text-transform: uppercase;">
        Done-For-You · 1-on-1 · $500 Flat
      </span>
      <h1 style="font-size: clamp(2rem, 5vw, 3.25rem); font-weight: 800; line-height: 1.1; margin: 0 0 20px;">
        Your Business. Automated.<br/>In One Session.
      </h1>
      <p style="font-size: 1.125rem; color: #4b5563; max-width: 560px; margin: 0 auto 32px; line-height: 1.6;">
        I map your workflow, build a live AI automation on the spot, and deliver a one-page report showing exactly what it saves you — time, money, and headaches. Done in 30 minutes. No tech skills needed.
      </p>
      <a href="#book"
        style="display: inline-block; background: #7c3aed; color: white; font-weight: 700; font-size: 1.1rem; padding: 16px 36px; border-radius: 10px; text-decoration: none;">
        Book Your AI Audit — $500
      </a>
      <p style="font-size: 0.8rem; color: #9ca3af; margin-top: 12px;">First 5 clients. Price goes to $1,000 after.</p>
    </div>
  </section>

  <!-- Social Proof Bar -->
  <section style="background: #f9fafb; border-top: 1px solid #f3f4f6; border-bottom: 1px solid #f3f4f6; padding: 20px 24px;">
    <div style="max-width: 720px; margin: 0 auto; display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; align-items: center; font-size: 0.875rem; color: #6b7280;">
      <span>✓ 826 likes on X for the audit framework</span>
      <span style="color: #d1d5db;">·</span>
      <span>✓ Results in one session, not weeks</span>
      <span style="color: #d1d5db;">·</span>
      <span>✓ Works for any service business</span>
    </div>
  </section>

  <!-- What You Get -->
  <section style="max-width: 720px; margin: 0 auto; padding: 64px 24px;">
    <h2 style="font-size: 1.75rem; font-weight: 800; text-align: center; margin-bottom: 8px;">What You Get</h2>
    <p style="text-align: center; color: #6b7280; margin-bottom: 48px;">Everything delivered in one 30-minute session — no follow-up calls, no waiting.</p>
    <div style="display: grid; gap: 20px;">
      {[
        { icon: "🗺️", title: "Workflow Mapping", desc: "We find the one task your team does every day that's eating your time. Booking confirmations, client emails, quote follow-ups — whatever's most painful." },
        { icon: "⚡", title: "Live Automation Build", desc: "I build the automation while you watch — using Zapier and ChatGPT, connected to tools you already use. You see it work in real time before the call ends." },
        { icon: "📄", title: "AI Audit Report", desc: "A one-page PDF: what was built, how many hours per week it saves, the dollar value of that time, and 3 more automations you could add next." },
        { icon: "🚀", title: "Upsell Roadmap", desc: "A clear picture of what else is possible — so you know exactly what your next step looks like if you want to keep going." },
      ].map(({ icon, title, desc }) => (
        <div style="display: flex; gap: 16px; padding: 24px; border: 1px solid #e5e7eb; border-radius: 12px;">
          <span style="font-size: 1.5rem; flex-shrink: 0;">{icon}</span>
          <div>
            <h3 style="font-weight: 700; margin: 0 0 6px;">{title}</h3>
            <p style="color: #6b7280; margin: 0; line-height: 1.6; font-size: 0.95rem;">{desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Who It's For -->
  <section style="background: #f0eaff; padding: 64px 24px;">
    <div style="max-width: 720px; margin: 0 auto;">
      <h2 style="font-size: 1.75rem; font-weight: 800; text-align: center; margin-bottom: 8px;">Who This Is For</h2>
      <p style="text-align: center; color: #6b7280; margin-bottom: 40px;">You don't need to know anything about AI. You just need a business that does repetitive work.</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px;">
        {["Hair & beauty salons", "Real estate agents", "Law offices", "Dental & medical clinics", "Restaurants & cafes", "Contractors & tradespeople", "Fitness studios", "Property managers"].map((biz) => (
          <div style="background: white; border-radius: 8px; padding: 12px 16px; font-size: 0.9rem; font-weight: 500; text-align: center; border: 1px solid #e5e7eb;">
            {biz}
          </div>
        ))}
      </div>
      <p style="text-align: center; margin-top: 24px; font-size: 0.9rem; color: #7c3aed; font-weight: 600;">
        If your team does the same tasks every day, there's something to automate.
      </p>
    </div>
  </section>

  <!-- Real Numbers -->
  <section style="max-width: 720px; margin: 0 auto; padding: 64px 24px;">
    <h2 style="font-size: 1.75rem; font-weight: 800; text-align: center; margin-bottom: 48px;">What the Numbers Look Like</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; text-align: center;">
      {[
        { stat: "6 hrs", label: "Average time saved per week from one automation" },
        { stat: "$480", label: "Monthly labor value recovered (at $20/hr)" },
        { stat: "15 min", label: "Customer response time vs 2–4 hours before" },
        { stat: "30 min", label: "That's all the session takes" },
      ].map(({ stat, label }) => (
        <div style="padding: 24px; background: #f9fafb; border-radius: 12px;">
          <div style="font-size: 2.25rem; font-weight: 800; color: #7c3aed; margin-bottom: 8px;">{stat}</div>
          <div style="font-size: 0.875rem; color: #6b7280; line-height: 1.5;">{label}</div>
        </div>
      ))}
    </div>
    <p style="text-align: center; font-size: 0.8rem; color: #9ca3af; margin-top: 20px;">Based on the Bella's Beauty Studio audit — results vary by business.</p>
  </section>

  <!-- Pricing -->
  <section style="background: #1a1035; color: white; padding: 64px 24px;">
    <div style="max-width: 500px; margin: 0 auto; text-align: center;">
      <h2 style="font-size: 1.75rem; font-weight: 800; margin-bottom: 8px;">Simple Pricing</h2>
      <p style="color: #a78bfa; margin-bottom: 40px;">No retainer. No surprise fees. One session, one price.</p>
      <div style="background: white; color: #1a1035; border-radius: 16px; padding: 40px;">
        <div style="font-size: 0.8rem; font-weight: 700; color: #7c3aed; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">AI Audit — Founding Rate</div>
        <div style="font-size: 3.5rem; font-weight: 800; line-height: 1; margin-bottom: 4px;">$500</div>
        <div style="color: #6b7280; font-size: 0.9rem; margin-bottom: 24px;">flat fee · first 5 clients only</div>
        <ul style="text-align: left; space-y: 8px; margin-bottom: 28px; list-style: none; padding: 0;">
          {["30-minute session via Zoom", "Live automation built while you watch", "One-page AI Audit Report PDF", "3 expansion automation ideas", "Retainer proposal if you want to keep going"].map((item) => (
            <li style="display: flex; gap: 10px; align-items: flex-start; margin-bottom: 10px; font-size: 0.95rem;">
              <span style="color: #7c3aed; font-weight: 700; flex-shrink: 0;">✓</span>
              {item}
            </li>
          ))}
        </ul>
        <a href="#book"
          style="display: block; background: #7c3aed; color: white; font-weight: 700; font-size: 1.05rem; padding: 14px 24px; border-radius: 10px; text-decoration: none; text-align: center;">
          Book Now — $500
        </a>
        <p style="font-size: 0.75rem; color: #9ca3af; margin-top: 12px;">Price increases to $1,000 after 5 clients.</p>
      </div>
    </div>
  </section>

  <!-- Book Section -->
  <section id="book" style="max-width: 720px; margin: 0 auto; padding: 64px 24px; text-align: center;">
    <h2 style="font-size: 1.75rem; font-weight: 800; margin-bottom: 8px;">Ready to Book?</h2>
    <p style="color: #6b7280; max-width: 480px; margin: 0 auto 32px; line-height: 1.6;">
      Pick a time that works for you. We'll spend 30 minutes mapping your workflow and building your first automation live on the call.
    </p>

    <!-- Booking form / Calendly placeholder -->
    <div id="booking-widget" style="background: #f9fafb; border: 2px dashed #e5e7eb; border-radius: 16px; padding: 48px 24px;">
      <p style="color: #9ca3af; font-size: 0.9rem; margin-bottom: 16px;">Booking calendar loads here</p>
      <p style="font-size: 0.8rem; color: #d1d5db;">
        <!-- REPLACE: embed Calendly widget script here, or replace this entire div with your booking solution -->
        Add your Calendly embed or booking link. See setup instructions below.
      </p>
    </div>

    <p style="margin-top: 24px; font-size: 0.875rem; color: #6b7280;">
      Questions first? DM me on
      <a href="https://x.com/thenelsonkwesi" style="color: #7c3aed; font-weight: 600;">X (@thenelsonkwesi)</a>
      or
      <a href="https://instagram.com/thenelsonkwesi" style="color: #7c3aed; font-weight: 600;">Instagram</a>.
    </p>
  </section>

  <!-- Footer -->
  <footer style="border-top: 1px solid #f3f4f6; padding: 32px 24px; text-align: center; font-size: 0.8rem; color: #9ca3af;">
    &copy; {new Date().getFullYear()} @thenelsonkwesi ·
    <a href="https://lead-pages-2.vercel.app" style="color: #7c3aed;">Free Resources</a>
  </footer>

</body>
</html>
