---
export const prerender = false;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>WALL // NELSONKWESI</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Kode+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:          #080A06;
      --amber:       #F0C030;
      --amber-dim:   rgba(240,192,48,0.55);
      --amber-faint: rgba(240,192,48,0.12);
      --ink:         #EDE8C8;
      --ink-dim:     rgba(237,232,200,0.52);
      --ink-faint:   rgba(237,232,200,0.18);
      --border:      rgba(240,192,48,0.22);
      --green:       rgba(100,230,100,0.9);
      --red:         rgba(230,80,80,0.9);
      --blue:        rgba(80,160,240,0.9);
      --font:        'Kode Mono', 'Courier New', monospace;
    }

    html, body {
      width: 100%; height: 100%;
      background: var(--bg);
      color: var(--ink);
      font-family: var(--font);
      overflow: hidden;
    }

    /* scanlines */
    body::before {
      content: ''; position: fixed; inset: 0;
      background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.12) 2px, rgba(0,0,0,0.12) 4px);
      pointer-events: none; z-index: 9999;
    }
    /* phosphor glow */
    body::after {
      content: ''; position: fixed; inset: 0;
      background: radial-gradient(ellipse 80% 70% at 50% 50%, rgba(240,192,48,0.025) 0%, transparent 70%);
      pointer-events: none; z-index: 0;
    }

    /* LAYOUT */
    .wall {
      display: grid;
      grid-template-rows: auto 1fr auto;
      height: 100vh;
      position: relative; z-index: 1;
    }

    /* TOP BAR */
    .top-bar {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      padding: 12px 28px;
      border-bottom: 1px solid var(--border);
    }
    .top-brand { font-size: 0.56rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--amber-dim); }
    .top-brand strong { color: var(--amber); }
    .top-clock { font-size: 3rem; font-weight: 700; color: var(--amber); text-shadow: 0 0 24px rgba(240,192,48,0.45); letter-spacing: 0.06em; line-height: 1; text-align: center; }
    .top-date { font-size: 0.56rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-dim); text-align: right; }

    /* BODY: main stage + sidebar */
    .body {
      display: grid;
      grid-template-columns: 1fr 260px;
      overflow: hidden;
    }

    /* MAIN STAGE */
    .stage {
      position: relative;
      overflow: hidden;
      border-right: 1px solid var(--border);
    }

    /* progress bar at bottom of stage */
    .stage-progress {
      position: absolute; bottom: 0; left: 0; right: 0; height: 2px;
      background: var(--amber-faint); z-index: 10;
    }
    .stage-progress-fill {
      height: 100%; width: 0%; background: var(--amber); opacity: 0.5;
      transition: width linear;
    }

    /* slide dots */
    .slide-dots {
      position: absolute; bottom: 10px; left: 0; right: 0;
      display: flex; justify-content: center; gap: 6px; z-index: 10;
    }
    .slide-dot { width: 5px; height: 5px; background: var(--amber-faint); }
    .slide-dot.on { background: var(--amber); }

    /* individual slides */
    .slide {
      position: absolute; inset: 0;
      display: flex; flex-direction: column; justify-content: center;
      padding: 48px 56px;
      opacity: 0;
      transition: opacity 0.6s ease;
    }
    .slide.visible { opacity: 1; }

    /* TASK SLIDE */
    .slide-eyebrow {
      font-size: 0.5rem; letter-spacing: 0.24em; text-transform: uppercase;
      color: var(--amber-dim); margin-bottom: 8px;
    }
    .slide-eyebrow::before { content: '// '; color: var(--amber); }
    .slide-project {
      font-size: clamp(1rem, 2vw, 1.4rem); font-weight: 700;
      color: var(--amber); letter-spacing: 0.06em; margin-bottom: 20px;
      text-shadow: 0 0 20px rgba(240,192,48,0.3);
    }
    .slide-task-name {
      font-size: clamp(1.8rem, 4vw, 3.2rem); font-weight: 700;
      color: var(--ink); line-height: 1.2; margin-bottom: 32px;
    }
    .slide-badges { display: flex; gap: 12px; flex-wrap: wrap; }
    .badge {
      font-size: 0.52rem; letter-spacing: 0.14em; text-transform: uppercase;
      padding: 5px 14px; border: 1px solid;
    }
    .badge-status-backlog     { color: var(--ink-dim);  border-color: rgba(237,232,200,0.2); }
    .badge-status-inprogress  { color: var(--amber);    border-color: var(--amber-dim); }
    .badge-status-blocked     { color: var(--red);      border-color: rgba(230,80,80,0.4); }
    .badge-status-done        { color: var(--green);    border-color: rgba(100,230,100,0.4); }
    .badge-status-notstarted  { color: var(--ink-dim);  border-color: rgba(237,232,200,0.2); }
    .badge-priority-high      { color: var(--red);      border-color: rgba(230,80,80,0.35); }
    .badge-priority-medium    { color: var(--amber-dim);border-color: rgba(240,192,48,0.25); }
    .badge-priority-low       { color: var(--ink-faint);border-color: rgba(237,232,200,0.12); }

    /* QUOTE SLIDE */
    .slide-quote { align-items: center; text-align: center; }
    .quote-label {
      font-size: 0.48rem; letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--amber-dim); margin-bottom: 32px;
    }
    .quote-label::before { content: '-- '; }
    .quote-body {
      font-size: clamp(1.6rem, 3.2vw, 2.6rem); font-weight: 700;
      color: var(--ink); line-height: 1.45; max-width: 720px;
      margin-bottom: 28px;
    }
    .quote-by {
      font-size: 0.66rem; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--amber);
    }
    .quote-by::before { content: '/ '; color: var(--amber-dim); }

    /* SIDEBAR */
    .sidebar {
      display: flex; flex-direction: column;
      padding: 20px 18px; gap: 6px; overflow: hidden;
    }
    .sidebar-label {
      font-size: 0.44rem; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--amber); margin-bottom: 8px;
    }
    .sidebar-label::before { content: '-- '; color: var(--amber-faint); }

    /* status counts */
    .counts-row { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; margin-bottom: 14px; }
    .cnt { border: 1px solid var(--border); padding: 8px 10px; text-align: center; }
    .cnt-num { font-size: 1.5rem; font-weight: 700; line-height: 1; }
    .cnt-num.c-backlog  { color: var(--ink-dim); }
    .cnt-num.c-progress { color: var(--amber); text-shadow: 0 0 10px rgba(240,192,48,0.4); }
    .cnt-num.c-blocked  { color: var(--red); }
    .cnt-num.c-done     { color: var(--green); }
    .cnt-lbl { font-size: 0.38rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-faint); margin-top: 2px; }

    /* sidebar task list */
    .sidebar-tasks { flex: 1; overflow: hidden; display: flex; flex-direction: column; gap: 4px; }
    .sb-task {
      padding: 7px 0;
      border-top: 1px solid rgba(240,192,48,0.07);
      display: flex; flex-direction: column; gap: 2px;
    }
    .sb-task:first-child { border-top: none; }
    .sb-task-name {
      font-size: 0.56rem; color: var(--ink-dim); line-height: 1.3;
      display: flex; gap: 7px;
    }
    .sb-task-name::before { content: '>'; color: var(--amber); flex-shrink: 0; }
    .sb-task-name.current { color: var(--ink); }
    .sb-task-name.current::before { color: var(--amber); }
    .sb-meta { font-size: 0.4rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-faint); padding-left: 14px; }
    .sb-proj-paperclip    { color: rgba(80,160,240,0.7); }
    .sb-proj-partnerships { color: var(--green); }
    .sb-proj-nelsonkwesi  { color: var(--amber-dim); }

    /* BOTTOM BAR */
    .bottom-bar {
      display: flex; justify-content: space-between; align-items: center;
      padding: 9px 28px; border-top: 1px solid var(--border);
      font-size: 0.54rem; letter-spacing: 0.1em; text-transform: uppercase;
    }
    .w-wrap { display: flex; gap: 12px; align-items: center; color: var(--ink-dim); }
    .w-temp { font-size: 1.1rem; font-weight: 700; color: var(--amber); }
    .sys-wrap { display: flex; gap: 12px; align-items: center; color: var(--amber-dim); }
    .blink { animation: blink 1.1s step-end infinite; }
    @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
  </style>
</head>
<body>
<div class="wall">

  <div class="top-bar">
    <div class="top-brand"><strong>NELSONKWESI</strong> // WALL DISPLAY</div>
    <div class="top-clock" id="clock">00:00:00</div>
    <div class="top-date" id="date-el"></div>
  </div>

  <div class="body">
    <div class="stage" id="stage">
      <div class="stage-progress"><div class="stage-progress-fill" id="prog-fill"></div></div>
      <div class="slide-dots" id="dots"></div>
    </div>

    <div class="sidebar">
      <div class="sidebar-label">Status</div>
      <div class="counts-row">
        <div class="cnt"><div class="cnt-num c-backlog" id="c-backlog">-</div><div class="cnt-lbl">Backlog</div></div>
        <div class="cnt"><div class="cnt-num c-progress" id="c-progress">-</div><div class="cnt-lbl">In Progress</div></div>
        <div class="cnt"><div class="cnt-num c-blocked" id="c-blocked">-</div><div class="cnt-lbl">Blocked</div></div>
        <div class="cnt"><div class="cnt-num c-done" id="c-done">-</div><div class="cnt-lbl">Done</div></div>
      </div>
      <div class="sidebar-label">All Tasks</div>
      <div class="sidebar-tasks" id="sidebar-tasks"></div>
    </div>
  </div>

  <div class="bottom-bar">
    <div class="w-wrap">
      <span class="w-temp" id="w-temp">--</span>
      <span id="w-city">Charlotte, NC</span>
      <span id="w-cond"></span>
    </div>
    <div class="sys-wrap">
      <span>REC <span class="blink">&#9679;</span></span>
      <span id="refresh-lbl">--</span>
      <span>SYS:ONLINE</span>
    </div>
  </div>

</div>
<script is:inline>
  const QUOTES = [
    { text: "Stay hungry. Stay foolish.", author: "Steve Jobs" },
    { text: "The people who are crazy enough to think they can change the world are the ones who do.", author: "Steve Jobs" },
    { text: "Your time is limited. Don't waste it living someone else's life.", author: "Steve Jobs" },
    { text: "Innovation distinguishes between a leader and a follower.", author: "Steve Jobs" },
    { text: "Design is not just what it looks like. Design is how it works.", author: "Steve Jobs" },
    { text: "The only way to do great work is to love what you do.", author: "Steve Jobs" },
    { text: "You are in danger of living a life so comfortable and soft that you will die without ever realizing your true potential.", author: "David Goggins" },
    { text: "Don't stop when you're tired. Stop when you're done.", author: "David Goggins" },
    { text: "The most important conversations you'll ever have are the ones you'll have with yourself.", author: "David Goggins" },
    { text: "Outwork everyone. Every single day.", author: "David Goggins" },
    { text: "We live in a world where mediocrity is rewarded. Don't accept that.", author: "David Goggins" },
    { text: "Discipline equals freedom.", author: "Jocko Willink" },
    { text: "Don't count on motivation. Count on discipline.", author: "Jocko Willink" },
    { text: "When things go bad, don't get startled. Look at the problem and execute.", author: "Jocko Willink" },
    { text: "Everything negative, pressure, challenges, is all an opportunity for me to rise.", author: "Kobe Bryant" },
    { text: "I have nothing in common with lazy people who blame others for their lack of success.", author: "Kobe Bryant" },
    { text: "The impediment to action advances action. What stands in the way becomes the way.", author: "Marcus Aurelius" },
    { text: "You have power over your mind, not outside events. Realize this, and you will find strength.", author: "Marcus Aurelius" },
    { text: "Hard work beats talent when talent doesn't work hard.", author: "Tim Notke" },
    { text: "You don't rise to the level of your goals. You fall to the level of your systems.", author: "James Clear" },
    { text: "Be so good they can't ignore you.", author: "Steve Martin" },
  ];

  function shuffle(a) {
    const b = [...a];
    for (let i = b.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [b[i], b[j]] = [b[j], b[i]];
    }
    return b;
  }

  const shuffledQ = shuffle(QUOTES);
  let qIdx = 0;

  // State
  let slides = [];
  let current = 0;
  let cycleTimer = null;
  const TASK_DURATION = 15000;
  const QUOTE_DURATION = 25000;

  function statusClass(s) {
    if (!s) return 'badge-status-notstarted';
    const n = s.toLowerCase().replace(/\s+/g, '');
    if (n === 'inprogress') return 'badge-status-inprogress';
    if (n === 'blocked') return 'badge-status-blocked';
    if (n === 'done') return 'badge-status-done';
    if (n === 'notstarted') return 'badge-status-notstarted';
    return 'badge-status-backlog';
  }

  function priorityClass(p) {
    if (!p) return 'badge-priority-low';
    const n = p.toLowerCase();
    if (n === 'high') return 'badge-priority-high';
    if (n === 'medium') return 'badge-priority-medium';
    return 'badge-priority-low';
  }

  function projectClass(proj) {
    if (!proj) return '';
    const n = proj.toLowerCase();
    if (n.includes('paperclip')) return 'sb-proj-paperclip';
    if (n.includes('partner')) return 'sb-proj-partnerships';
    return 'sb-proj-nelsonkwesi';
  }

  function buildTaskSlide(task) {
    const div = document.createElement('div');
    div.className = 'slide';

    const eyebrow = document.createElement('div');
    eyebrow.className = 'slide-eyebrow';
    eyebrow.textContent = 'Active Task';
    div.appendChild(eyebrow);

    const proj = document.createElement('div');
    proj.className = 'slide-project';
    proj.textContent = task.project || '';
    div.appendChild(proj);

    const name = document.createElement('div');
    name.className = 'slide-task-name';
    name.textContent = task.name;
    div.appendChild(name);

    const badges = document.createElement('div');
    badges.className = 'slide-badges';

    const sb = document.createElement('span');
    sb.className = 'badge ' + statusClass(task.status);
    sb.textContent = task.status || 'Backlog';
    badges.appendChild(sb);

    if (task.priority) {
      const pb = document.createElement('span');
      pb.className = 'badge ' + priorityClass(task.priority);
      pb.textContent = task.priority;
      badges.appendChild(pb);
    }

    div.appendChild(badges);
    return div;
  }

  function buildQuoteSlide(q) {
    const div = document.createElement('div');
    div.className = 'slide slide-quote';

    const lbl = document.createElement('div');
    lbl.className = 'quote-label';
    lbl.textContent = 'Keep Going';
    div.appendChild(lbl);

    const body = document.createElement('div');
    body.className = 'quote-body';
    body.textContent = q.text;
    div.appendChild(body);

    const by = document.createElement('div');
    by.className = 'quote-by';
    by.textContent = q.author;
    div.appendChild(by);

    return div;
  }

  function buildDots() {
    const c = document.getElementById('dots');
    while (c.firstChild) c.removeChild(c.firstChild);
    slides.forEach((_, i) => {
      const d = document.createElement('div');
      d.className = 'slide-dot' + (i === current ? ' on' : '');
      c.appendChild(d);
    });
  }

  function updateDots() {
    const dots = document.getElementById('dots').children;
    for (let i = 0; i < dots.length; i++) {
      dots[i].className = 'slide-dot' + (i === current ? ' on' : '');
    }
  }

  function startProgress(ms) {
    const fill = document.getElementById('prog-fill');
    fill.style.transition = 'none';
    fill.style.width = '0%';
    requestAnimationFrame(() => requestAnimationFrame(() => {
      fill.style.transition = 'width ' + ms + 'ms linear';
      fill.style.width = '100%';
    }));
  }

  function showSlide(idx) {
    slides.forEach((s, i) => s.el.classList.toggle('visible', i === idx));
    updateDots();
    startProgress(slides[idx].duration);

    // Update sidebar highlight
    const sbItems = document.querySelectorAll('.sb-task-name');
    sbItems.forEach((el, i) => {
      el.classList.toggle('current', slides[idx].taskIndex === i);
    });
  }

  function next() {
    current = (current + 1) % slides.length;
    showSlide(current);
    schedule();
  }

  function schedule() {
    clearTimeout(cycleTimer);
    cycleTimer = setTimeout(next, slides[current].duration);
  }

  function buildSlides(tasks) {
    const stage = document.getElementById('stage');
    stage.querySelectorAll('.slide').forEach(s => s.remove());
    slides = [];

    const active = tasks.filter(t => {
      const s = (t.status || '').toLowerCase().replace(/\s+/g, '');
      return s !== 'done';
    });

    // Interleave: every 3 tasks insert a quote
    active.forEach((task, i) => {
      const el = buildTaskSlide(task);
      stage.insertBefore(el, document.getElementById('dots'));
      slides.push({ el, duration: TASK_DURATION, taskIndex: i });

      if ((i + 1) % 3 === 0) {
        qIdx = (qIdx + 1) % shuffledQ.length;
        const qel = buildQuoteSlide(shuffledQ[qIdx]);
        stage.insertBefore(qel, document.getElementById('dots'));
        slides.push({ el: qel, duration: QUOTE_DURATION, taskIndex: -1 });
      }
    });

    // Always end with a quote if last slide wasn't one
    if (slides.length === 0 || slides[slides.length - 1].taskIndex !== -1) {
      qIdx = (qIdx + 1) % shuffledQ.length;
      const qel = buildQuoteSlide(shuffledQ[qIdx]);
      stage.insertBefore(qel, document.getElementById('dots'));
      slides.push({ el: qel, duration: QUOTE_DURATION, taskIndex: -1 });
    }

    buildDots();
  }

  function buildSidebar(tasks) {
    const el = document.getElementById('sidebar-tasks');
    while (el.firstChild) el.removeChild(el.firstChild);

    tasks.forEach(t => {
      const item = document.createElement('div');
      item.className = 'sb-task';

      const nameRow = document.createElement('div');
      nameRow.className = 'sb-task-name';
      nameRow.textContent = t.name;
      item.appendChild(nameRow);

      const meta = document.createElement('div');
      meta.className = 'sb-meta';

      const projSpan = document.createElement('span');
      projSpan.className = projectClass(t.project);
      projSpan.textContent = t.project;
      meta.appendChild(projSpan);

      const sep = document.createTextNode(' / ');
      meta.appendChild(sep);

      const stSpan = document.createElement('span');
      stSpan.textContent = t.status || 'Backlog';
      meta.appendChild(stSpan);

      item.appendChild(meta);
      el.appendChild(item);
    });
  }

  // Clock
  const DAYS = ['SUN','MON','TUE','WED','THU','FRI','SAT'];
  const MONTHS = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
  function tick() {
    const n = new Date();
    const p = x => String(x).padStart(2,'0');
    document.getElementById('clock').textContent = p(n.getHours()) + ':' + p(n.getMinutes()) + ':' + p(n.getSeconds());
    document.getElementById('date-el').textContent = DAYS[n.getDay()] + ' ' + p(n.getDate()) + ' ' + MONTHS[n.getMonth()] + ' ' + n.getFullYear();
  }
  tick(); setInterval(tick, 1000);

  // Tasks
  async function loadTasks() {
    try {
      const res = await fetch('/api/notion-tasks');
      const data = await res.json();
      document.getElementById('c-backlog').textContent = data.counts.backlog;
      document.getElementById('c-progress').textContent = data.counts.inProgress;
      document.getElementById('c-blocked').textContent = data.counts.blocked;
      document.getElementById('c-done').textContent = data.counts.done;

      clearTimeout(cycleTimer);
      buildSlides(data.tasks);
      buildSidebar(data.tasks);
      current = 0;
      showSlide(0);
      schedule();

      const n = new Date();
      const p = x => String(x).padStart(2,'0');
      document.getElementById('refresh-lbl').textContent = 'REFRESH ' + p(n.getHours()) + ':' + p(n.getMinutes());
    } catch (_) {}
  }

  // Weather
  function applyWeather(d) {
    if (d.temp && d.temp !== '--' && d.temp !== null) {
      document.getElementById('w-temp').textContent = d.temp + 'F';
      document.getElementById('w-city').textContent = d.city || 'Charlotte, NC';
      document.getElementById('w-cond').textContent = d.condition || '';
    }
  }
  function fetchWeather(lat, lon) {
    fetch('/api/weather?lat=' + lat + '&lon=' + lon).then(r => r.json()).then(applyWeather).catch(() => {});
  }
  function initWeather() {
    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(
        p => fetchWeather(p.coords.latitude, p.coords.longitude),
        () => fetchWeather('35.2271', '-80.8431')
      );
    } else {
      fetchWeather('35.2271', '-80.8431');
    }
  }

  loadTasks();
  initWeather();
  setInterval(loadTasks, 120000);
  setInterval(initWeather, 600000);
</script>
</body>
</html>
